# =============================================================================
# SuperMemory Clone - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# All variables with default values are optional.
# =============================================================================

# =============================================================================
# REQUIRED: API Keys (at least one is needed for embeddings)
# =============================================================================

# OpenAI API Key - Required for embeddings (unless using local embeddings)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# =============================================================================
# OPTIONAL: Anthropic API Key (for LLM-based memory extraction)
# =============================================================================

# Anthropic API Key - Optional, enables Claude-based memory extraction
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# =============================================================================
# Secrets Management (REQUIRED for production)
# =============================================================================

# Master password for encrypting secrets at rest
# REQUIRED for production deployment
# Generate with: openssl rand -base64 48
# Minimum 16 characters, recommended 32+ characters
# IMPORTANT: Store securely (e.g., AWS Secrets Manager, HashiCorp Vault)
SECRETS_MASTER_PASSWORD=

# Salt for key derivation (base64 encoded)
# Optional: If not provided, a new salt is generated on first run
# IMPORTANT: Must be consistent across restarts for decryption to work
# Generate with: openssl rand -base64 24
SECRETS_SALT=

# =============================================================================
# Server Configuration
# =============================================================================

# Port the API server listens on
# Default: 3000
API_PORT=3000

# Host the API server binds to
# Use 0.0.0.0 for Docker containers, localhost for local development
# Default: localhost
API_HOST=localhost

# =============================================================================
# Authentication
# =============================================================================

# Secret key for API authentication (used in X-API-Key header)
# For production, use a strong random string (32+ characters)
# Optional: If not set, authentication is disabled (MCP mode)
API_SECRET_KEY=your-secret-key-here

# CSRF secret key for token signing (REQUIRED in production)
# Generate with: openssl rand -base64 48
# Minimum 32 characters required for security
# Default: Generated in development (not secure for production)
CSRF_SECRET=

# Allowed origins for CSRF validation (comma-separated)
# Should match your frontend origins
# Default: http://localhost:3000,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# Database Configuration
# =============================================================================

# SQLite database path for metadata and memory storage
# Default: ./data/supermemory.db
DATABASE_URL=./data/supermemory.db

# =============================================================================
# Embedding Configuration
# =============================================================================

# OpenAI embedding model to use
# Options: text-embedding-3-small, text-embedding-3-large, text-embedding-ada-002
# Default: text-embedding-3-small
EMBEDDING_MODEL=text-embedding-3-small

# Embedding vector dimensions
# text-embedding-3-small: 1536 (default) or 512
# text-embedding-3-large: 3072 or 1536 or 256
# Default: 1536
EMBEDDING_DIMENSIONS=1536

# =============================================================================
# Vector Store Configuration
# =============================================================================

# Vector store provider for similarity search
# Options:
#   - memory: In-memory store (fast, not persistent, good for development)
#   - sqlite-vss: SQLite with VSS extension (persistent, single-node)
#   - chroma: ChromaDB server (persistent, scalable, recommended for production)
# Default: memory
VECTOR_STORE_PROVIDER=memory

# Vector dimensions (should match EMBEDDING_DIMENSIONS)
# Default: 1536
VECTOR_DIMENSIONS=1536

# SQLite VSS database path (only used when VECTOR_STORE_PROVIDER=sqlite-vss)
# Default: ./data/vectors.db
VECTOR_SQLITE_PATH=./data/vectors.db

# ChromaDB server URL (only used when VECTOR_STORE_PROVIDER=chroma)
# Default: http://localhost:8000
CHROMA_URL=http://localhost:8000

# ChromaDB collection name
# Default: supermemory_vectors
CHROMA_COLLECTION=supermemory_vectors

# =============================================================================
# LLM Provider Configuration (for Memory Extraction)
# =============================================================================

# LLM provider for intelligent memory extraction
# Options:
#   - (empty): Disabled, uses pattern-based extraction only
#   - openai: Use OpenAI GPT models
#   - anthropic: Use Anthropic Claude models
#   - mock: Mock provider for testing
# Default: (empty - disabled)
LLM_PROVIDER=

# Override the default model for the selected provider
# OpenAI default: gpt-4o-mini
# Anthropic default: claude-3-haiku-20240307
# Leave empty to use provider defaults
LLM_MODEL=

# Maximum tokens for LLM responses
# Default: 2000
LLM_MAX_TOKENS=2000

# Temperature for LLM generation (0-2)
# Lower = more deterministic, higher = more creative
# Default: 0.1 (deterministic for extraction)
LLM_TEMPERATURE=0.1

# Timeout for LLM requests in milliseconds
# Default: 30000 (30 seconds)
LLM_TIMEOUT_MS=30000

# Maximum retries on LLM failure
# Default: 3
LLM_MAX_RETRIES=3

# =============================================================================
# LLM Caching Configuration
# =============================================================================

# Enable caching of LLM responses
# Reduces costs and latency for repeated content
# Default: true
LLM_CACHE_ENABLED=true

# Cache time-to-live in milliseconds
# Default: 900000 (15 minutes)
LLM_CACHE_TTL_MS=900000

# =============================================================================
# Rate Limiting
# =============================================================================

# Maximum requests per window
# Default: 100
RATE_LIMIT_REQUESTS=100

# Rate limit window in milliseconds
# Default: 60000 (1 minute)
RATE_LIMIT_WINDOW_MS=60000

# =============================================================================
# Logging
# =============================================================================

# Log level
# Options: debug, info, warn, error
# Default: info
LOG_LEVEL=info

# =============================================================================
# Redis Configuration (optional - for caching and job queues)
# =============================================================================

# Redis connection URL
# Only needed when running with Redis profile
# Default: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# Redis host and port (alternative to REDIS_URL)
# REDIS_HOST=localhost
# REDIS_PORT=6379

# =============================================================================
# BullMQ Job Queue Configuration
# =============================================================================

# Concurrency settings for each queue type
# Controls how many jobs can be processed simultaneously per queue
# Default values optimized for typical workloads

# Document extraction queue concurrency
# Default: 5
BULLMQ_CONCURRENCY_EXTRACTION=5

# Text chunking queue concurrency
# Default: 3
BULLMQ_CONCURRENCY_CHUNKING=3

# Embedding generation queue concurrency
# Default: 2 (embedding generation is resource-intensive)
BULLMQ_CONCURRENCY_EMBEDDING=2

# Vector indexing queue concurrency
# Default: 1 (prevent race conditions in vector store)
BULLMQ_CONCURRENCY_INDEXING=1

# =============================================================================
# PostgreSQL Configuration (optional - production database)
# =============================================================================

# PostgreSQL connection URL (overrides DATABASE_URL for SQLite)
# Only needed when running with PostgreSQL profile
# Format: postgresql://user:password@host:port/database
# Default: (not set - uses SQLite)
# DATABASE_URL=postgresql://supermemory:supermemory_secret@localhost:5432/supermemory

# =============================================================================
# Docker Entrypoint Configuration
# =============================================================================

# Skip database migrations on startup
# Default: false
SKIP_MIGRATIONS=false

# Maximum connection retry attempts
# Default: 30
MAX_RETRIES=30

# Seconds between connection retries
# Default: 2
RETRY_INTERVAL=2
