# =============================================================================
# Docker Ignore File
# =============================================================================
# Files and directories listed here will NOT be copied to the Docker build
# context. This speeds up builds and reduces image size.
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies - Use npm ci in Docker instead
# -----------------------------------------------------------------------------
node_modules
.npm
.pnpm-store

# -----------------------------------------------------------------------------
# Build outputs - Will be regenerated in Docker
# -----------------------------------------------------------------------------
dist
build
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Environment and secrets - NEVER include in images
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets/

# -----------------------------------------------------------------------------
# Git and version control
# -----------------------------------------------------------------------------
.git
.gitignore
.gitattributes
.github

# -----------------------------------------------------------------------------
# IDE and editor configurations
# -----------------------------------------------------------------------------
.idea
.vscode
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Documentation - Not needed in production image
# -----------------------------------------------------------------------------
*.md
!LICENSE.md
docs/
CHANGELOG*
CONTRIBUTING*
README*

# -----------------------------------------------------------------------------
# Tests - Not needed in production image
# -----------------------------------------------------------------------------
tests/
test/
__tests__/
*.test.ts
*.test.js
*.spec.ts
*.spec.js
coverage/
.nyc_output/
vitest.config.ts
jest.config.*

# -----------------------------------------------------------------------------
# Development and tooling
# -----------------------------------------------------------------------------
.claude/
.claude-flow/
.swarm/
.mcp.json
CLAUDE.md
*.log
logs/

# Docker files - Prevent recursive copying
Dockerfile*
docker-compose*.yml
.docker/

# CI/CD configurations
.circleci/
.travis.yml
.gitlab-ci.yml
azure-pipelines.yml
Jenkinsfile

# -----------------------------------------------------------------------------
# Data and database files - Should be mounted as volumes
# -----------------------------------------------------------------------------
data/
*.db
*.sqlite
*.sqlite3

# -----------------------------------------------------------------------------
# Temporary and cache files
# -----------------------------------------------------------------------------
tmp/
temp/
.cache/
*.tmp
*.temp
drizzle/

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
*.tgz
*.tar.gz
*.zip
Makefile
